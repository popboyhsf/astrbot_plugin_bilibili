{
    "sessdata": {
        "description": "sessdata",
        "type": "string",
        "hint": "sessdata 获取请查看 readme",
        "obvious_hint": true
    },
    "proxy": {
        "description": "proxy",
        "type": "string",
        "hint": "Bilibili API 请求代理地址。示例: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080，留空则直连。",
        "default": ""
    },
    "interval_mins": {
        "description": "interval_mins",
        "type": "int",
        "hint": "单个UP主任务的检测周期，分钟数",
        "obvious_hint": true,
        "default": 5
    },
    "task_gap_secs": {
        "description": "task_gap_secs",
        "type": "int",
        "hint": "相邻两个UP主任务的最小间隔，秒数",
        "default": 20
    },
    "rai": {
        "description": "render_as_image",
        "type": "bool",
        "hint": "是否以图片形式渲染输出(仅对图文动态生效)",
        "default": true
    },
    "renderer_template": {
        "description": "renderer_template",
        "type": "string",
        "hint": "渲染模板",
        "options": ["template_1", "template_2", "simple"],
        "default": "template_2"
    },
    "node": {
        "description": "node",
        "type": "bool",
        "hint": "是否以转发消息形式推送(仅对图文动态生效)",
        "default": false
    },
    "telegram_media_group": {
        "description": "telegram_media_group",
        "type": "bool",
        "hint": "Telegram图文动态是否改为多媒体组发送(多图/GIF，不走合成大图)",
        "default": false
    },
    "telegram_media_group_min_count": {
        "description": "telegram_media_group_min_count",
        "type": "int",
        "hint": "仅当图文动态图片数量>=该值时，Telegram才走多媒体组发送",
        "default": 2
    },
    "enable_parse_miniapp": {
        "description": "enable_parse_miniapp",
        "type": "bool",
        "hint": "是否解析小程序",
        "default": true
    },
    "enable_parse_BV": {
        "description": "enable_parse_BV",
        "type": "bool",
        "hint": "是否解析B站视频链接",
        "default": true
    },
    "dynamic_limit": {
        "description": "dynamic_limit",
        "type": "int",
        "hint": "每个UP主的单次动态推送数量限制",
        "default": 5
    }
}


